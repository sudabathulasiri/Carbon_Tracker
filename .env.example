# ─────────────────────────────────────────────────────────────────────────────
# Carbon Footprint Tracker — Environment Variables
# Copy this file to server/.env and fill in your values.
# NEVER commit .env files to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on
PORT=5000

# Node environment: development | production | test
NODE_ENV=development


# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Full MongoDB connection string (Atlas URI or local instance)
# Example (Atlas):  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/carbon_tracker?retryWrites=true&w=majority
# Example (local):  mongodb://localhost:27017/carbon_tracker
MONGO_URI=mongodb://localhost:27017/carbon_tracker


# ─── Authentication (JWT) ─────────────────────────────────────────────────────
# A long, random secret string used to sign JWT tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_secure_random_64_char_hex_string

# Token expiry duration (e.g. 7d, 24h, 30d)
JWT_EXPIRES_IN=7d

# Refresh token expiry duration
JWT_REFRESH_EXPIRES_IN=30d


# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Development:  http://localhost:5173
# Production:   https://your-app-domain.com
CLIENT_ORIGIN=http://localhost:5173


# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Max requests per IP per window (default: 100 requests per 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
